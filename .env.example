# ============================================================================
# AutomationX V3 Enterprise Platform — Production Environment Configuration
# ============================================================================

# ----------------------------------------------------------------------------
# 1. Platform & Application Runtime Settings
# ----------------------------------------------------------------------------
# Required: YES
# Default: development
# Description: Application execution environment (development | production | test)
NODE_ENV=production

# Required: YES
# Default: 3000
# Description: Fastify HTTP server listening port
PORT=3000

# Required: YES
# Default: http://localhost:3000
# Description: Public HTTP endpoint URL of the backend API
BACKEND_PUBLIC_URL=https://api.automationx.company.com

# Required: NO
# Default: info
# Description: Logging level threshold (trace | debug | info | warn | error | fatal)
LOG_LEVEL=info

# Required: OPTIONAL
# Default: (none)
# Description: Secret key for authenticating internal API management requests
API_KEY=your_secure_api_key_here

# Required: OPTIONAL
# Default: (none)
# Description: Secret HMAC key for verifying incoming webhook signatures
WEBHOOK_SECRET=your_webhook_hmac_secret

# Required: NO
# Default: 60
# Description: Maximum API requests allowed per window per IP
RATE_LIMIT_MAX=60

# Required: NO
# Default: 60000
# Description: Rate limiting window duration in milliseconds
RATE_LIMIT_WINDOW_MS=60000


# ----------------------------------------------------------------------------
# 2. PostgreSQL Database Infrastructure
# ----------------------------------------------------------------------------
# Required: YES
# Default: postgres
# Description: Database adapter provider (postgres | local | nocodb)
DATABASE_PROVIDER=postgres

# Required: YES
# Default: postgresql://automationx_app:password@localhost:5432/automationx_db
# Description: Primary PostgreSQL connection string (supports pgvector)
DATABASE_URL=postgresql://automationx_app:SecurePassword123!@postgres.prod.internal:5432/automationx_db

# Required: NO
# Default: (none)
# Description: Optional read-replica PostgreSQL connection string
DATABASE_REPLICA_URL=postgresql://automationx_app:SecurePassword123!@postgres-replica.prod.internal:5432/automationx_db

# Required: NO
# Default: 10
# Description: Maximum connections in the PostgreSQL connection pool
DB_POOL_MAX=20

# Required: NO
# Default: 30000
# Description: Connection idle timeout before closing (ms)
DB_POOL_IDLE_TIMEOUT_MS=30000

# Required: NO
# Default: 2000
# Description: Max time to wait for a database connection (ms)
DB_POOL_CONNECTION_TIMEOUT_MS=2000


# ----------------------------------------------------------------------------
# 3. Redis, Cache & BullMQ Queue Infrastructure
# ----------------------------------------------------------------------------
# Required: YES
# Default: redis
# Description: Queue provider implementation (redis | memory)
QUEUE_PROVIDER=redis

# Required: YES
# Default: redis
# Description: Cache & Takeover lock provider implementation (redis | memory)
CACHE_PROVIDER=redis

# Required: YES
# Default: redis://127.0.0.1:6379
# Description: Production Redis connection URI (supports Sentinel / Cluster)
REDIS_URL=redis://:RedisSecureAuthPassword123!@redis.prod.internal:6379/0


# ----------------------------------------------------------------------------
# 4. PromptX AI & MCP Tool Integration
# ----------------------------------------------------------------------------
# Required: YES
# Default: (none)
# Description: URL endpoint of the PromptX Model Context Protocol (MCP) Server
PROMPTX_MCP_URL=https://mcp.promptxai.com

# Required: YES
# Default: (none)
# Description: Authentication token for invoking PromptX MCP tools
PROMPTX_MCP_TOKEN=px_mcp_live_token_77a8b9c0

# Required: YES
# Default: (none)
# Description: PromptX Webhook flow execution endpoint URL
PROMPTX_FLOW_WEBHOOK_URL=https://wf.promptxai.com/api/v1/webhooks/Tj4kqSult1bbWIx2I2w4H

# Required: NO
# Default: 3
# Description: Maximum allowed consecutive AI-to-Human handoff attempts
MAX_AGENT_HANDOFF_DEPTH=3

# Required: NO
# Default: mock
# Description: RAG Embedding provider mode (mock | external)
EMBEDDING_PROVIDER=external


# ----------------------------------------------------------------------------
# 5. LINE OA Messaging Integration
# ----------------------------------------------------------------------------
# Required: YES
# Default: (none)
# Description: Official LINE Channel Access Token (Long-Lived) for Push API
LINE_CHANNEL_ACCESS_TOKEN=Your_Official_LINE_Channel_Access_Token_Here


# ----------------------------------------------------------------------------
# 6. Plane.so Project Management Sync Integration
# ----------------------------------------------------------------------------
# Required: YES (if Plane sync enabled)
# Default: https://api.plane.so
# Description: Base REST API URL of the Plane.so instance
PLANE_API_URL=https://api.plane.so

# Required: YES (if Plane sync enabled)
# Default: (none)
# Description: Plane.so API Token for creating and syncing issues
PLANE_API_KEY=plane_api_live_token_abc123

# Required: YES (if Plane sync enabled)
# Default: (none)
# Description: Target Plane Project UUID
PLANE_PROJECT_ID=6a98010e-36a9-4383-943d-c716e3e41dab

# Required: YES (if Plane sync enabled)
# Default: (none)
# Description: Target Plane Workspace Slug
PLANE_WORKSPACE_SLUG=automationx-workspace

# Required: NO
# Default: false
# Description: Enable background polling to sync ticket updates from Plane.so
PLANE_REVERSE_SYNC_ENABLED=false

# Required: NO
# Default: 30000
# Description: Reverse sync interval in milliseconds
PLANE_REVERSE_SYNC_INTERVAL_MS=30000

# Required: NO
# Default: 25
# Description: Maximum tickets fetched per reverse sync batch
PLANE_REVERSE_SYNC_BATCH_SIZE=25


# ----------------------------------------------------------------------------
# 7. Human Takeover & Operator Lease Policy
# ----------------------------------------------------------------------------
# Required: NO
# Default: 5
# Description: Time before unassigned human takeover request times out (minutes)
HUMAN_PENDING_TIMEOUT_MINUTES=5

# Required: NO
# Default: 15
# Description: Inactivity timeout before human operator takeover lease expires (minutes)
HUMAN_ACTIVE_TIMEOUT_MINUTES=15

# Required: NO
# Default: 60
# Description: Hard maximum duration for a human takeover session (minutes)
HUMAN_MAX_SESSION_MINUTES=60

# Required: NO
# Default: 480
# Description: Legacy takeover session timeout compatibility (minutes)
HUMAN_SESSION_TIMEOUT_MINUTES=480


# ----------------------------------------------------------------------------
# 8. Activepieces Workflow Gateway URLs (V2/V3)
# ----------------------------------------------------------------------------
# Required: NO
# Default: (none)
# Description: Activepieces Human Reply Webhook Endpoint URL
ACTIVEPIECES_HUMAN_REPLY_WEBHOOK_URL=https://wf.promptxai.com/api/v1/webhooks/HGkKjrGFq4Aw2wmaZLK7j

# Required: NO
# Default: (none)
# Description: Activepieces Promote Ticket Webhook Endpoint URL
ACTIVEPIECES_PROMOTE_TICKET_WEBHOOK_URL=https://wf.promptxai.com/api/v1/webhooks/cprgnt201vTw2zX8YQycQ


# ----------------------------------------------------------------------------
# 9. Storage, Security & Backup Keys
# ----------------------------------------------------------------------------
# Required: YES
# Default: (none)
# Description: 32-character AES encryption key for database backup files
BACKUP_ENCRYPTION_KEY=prod_super_secret_backup_key_32c