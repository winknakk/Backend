# ─── System Environment ──────────────────────────────────────
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# ─── Database Configurations ─────────────────────────────────
DATABASE_PROVIDER=postgres
DATABASE_URL=postgresql://automationx:changeme@automationx-postgres-primary:5432/automationx
DATABASE_REPLICA_URL=postgresql://automationx:changeme@automationx-postgres-replica:5432/automationx

# ─── Database Client Pool Settings ───────────────────────────
DB_POOL_MAX=15
DB_POOL_IDLE_TIMEOUT_MS=30000
DB_POOL_CONNECTION_TIMEOUT_MS=3000

# ─── Disaster Recovery Encryption ─────────────────────────────
# Key must be exactly 32 characters for AES-256-CBC
BACKUP_ENCRYPTION_KEY=super-secret-backup-key-32-chars!

# ─── Redis Caching & BullMQ Configuration ─────────────────────
QUEUE_PROVIDER=redis
CACHE_PROVIDER=redis
REDIS_URL=redis://automationx-redis:6379

# ─── Integration MCP Services ─────────────────────────────────
NOCODB_BASE_URL=https://app.nocodb.com/
NOCODB_TOKEN=your-nocodb-token-here

PROMPTX_MCP_URL=https://wf.promptxai.com/api/v1/projects/...
PROMPTX_MCP_TOKEN=Bearer your-mcp-token-here

# ─── Security Middlwares ─────────────────────────────────────
API_KEY=your-api-key-here
WEBHOOK_SECRET=your-webhook-hmac-secret-here
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ─── Agent Reasoning Controls ────────────────────────────────
MAX_AGENT_HANDOFF_DEPTH=3
POLICY_FILE_PATH=data/policies.json
