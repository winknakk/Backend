{
  "name": "find_ticket",
  "version": "2.0",
  "description": "Search and filter tickets by project, status, or conversation.",
  "category": "tickets",
  "owner": "platform-engineering",
  "executionMode": "sync",
  "requiredPermissions": ["find_ticket"],
  "backend": {
    "method": "GET",
    "endpoint": "/api/v1/internal/tickets/status"
  },
  "inputSchema": {
    "type": "object",
    "properties": {
      "projectId": { "type": "string", "description": "The relevant project ID" },
      "status": { "type": "string", "description": "Filter by ticket status (e.g. Open, In Progress, Closed, Merged)" },
      "conversationId": { "type": "string", "description": "Filter by active conversation ID" }
    }
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "success": { "type": "boolean" },
      "data": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "id": { "type": "string" },
            "ticketId": { "type": "string" },
            "conversationId": { "type": "string" },
            "projectId": { "type": "string" },
            "subject": { "type": "string" },
            "summary": { "type": "string" },
            "status": { "type": "string" },
            "priority": { "type": "string" },
            "severity": { "type": "string" }
          }
        }
      },
      "error": { "type": "null" }
    }
  },
  "events": {
    "publish": [],
    "subscribe": []
  },
  "automationX": {
    "flow": "nocodb-ticket-search",
    "waitForEvents": [],
    "nextEvents": []
  },
  "agentX": {
    "reasoningHints": ["Use this tool to find matching tickets or check if an issue is already being tracked under the active conversation or project."],
    "memoryUsage": "none",
    "requiresEnrichedTicket": false
  },
  "retryPolicy": {
    "enabled": true,
    "maxAttempts": 3,
    "backoff": "exponential"
  },
  "idempotency": {
    "enabled": false,
    "key": ""
  },
  "observability": {
    "metrics": ["find_ticket_total", "find_ticket_latency"],
    "logs": ["Searching tickets for conversation {conversationId} status {status}"],
    "trace": true
  }
}
